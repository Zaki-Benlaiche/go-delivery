# Server
PORT=3001
NODE_ENV=development

# Security — generate a strong random string for production
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Database — PostgreSQL (Neon recommended; works with any Postgres provider)
# Use the pooled connection string from Neon (host contains "-pooler") for Render.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Frontend URL — used to restrict CORS in production
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
